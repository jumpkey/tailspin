# Raw data (large, idempotently re-downloadable)
# Comment out if you want to commit small raw samples
data/raw/bts/*.csv
data/raw/faa/*.csv
data/raw/flightaware/*.json
# Always keep manifests
!data/raw/bts/manifest.csv
!data/raw/faa/manifest.csv
!data/raw/flightaware/manifest.csv

# Staging (derived from raw)
data/staging/*.csv

# Curated fact table (large; regenerated by pipeline)
data/curated/flight_operability_fact.csv
